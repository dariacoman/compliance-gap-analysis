# Copy to `.env` and fill in. The .env file is gitignored.

# Primary backend — Llama 70B via Groq free tier.
# Get a key at https://console.groq.com (free, no credit card).
GROQ_API_KEY=

# Eval-phase only — Anthropic API for the Opus gold-set bootstrap script.
# Not required for the build phase. Set up before eval-phase begins to
# avoid discovering this dependency mid-eval. The bootstrap is a one-off
# script outside the FLEX-6 LLM abstraction (no caching, single use).
# Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=
